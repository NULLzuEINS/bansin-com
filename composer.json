{
    "name": "bansin-com/website",
    "description": "Bansin.com Website",
    "type": "project",
    "require": {
        "php": ">=8.2"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "squizlabs/php_codesniffer": "^3.7",
        "phpstan/phpstan": "^1.10",
        "friendsofphp/php-cs-fixer": "^3.13"
    },
    "autoload": {
        "psr-4": {
            "Bansin\\": "cron/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Bansin\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "phpcs": "phpcs",
        "phpstan": "phpstan analyse",
        "php-cs-fixer": "php-cs-fixer fix"
    },
    "config": {
        "sort-packages": true
    }
}
